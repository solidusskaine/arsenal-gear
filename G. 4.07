import sys

def solve_three_friends():
    # Leer toda la entrada de golpe elimina problemas de formato y saltos de línea
    input_data = sys.stdin.read().split()
    if not input_data:
        return
        
    q = int(input_data[0])
    idx = 1
    
    out = []
    
    for _ in range(q):
        a = int(input_data[idx])
        b = int(input_data[idx+1])
        c = int(input_data[idx+2])
        idx += 3
        
        # Encontramos quién está más a la izquierda y quién más a la derecha
        min_pos = min(a, b, c)
        max_pos = max(a, b, c)
        
        # Acercamos los extremos: la diferencia máxima se reduce en 2.
        # Usamos max(0, ...) porque la distancia nunca puede ser negativa si ya estaban juntos.
        nueva_diferencia = max(0, max_pos - min_pos - 2)
        
        # La distancia total por pares es siempre el doble de la diferencia entre extremos
        out.append(str(nueva_diferencia * 2))
        
    # Imprimimos todo el bloque de respuestas de una vez
    print('\n'.join(out))

if __name__ == '__main__':
    solve_three_friends()
