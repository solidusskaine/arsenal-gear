import sys
from collections import Counter

def solve_pockets():
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    n = int(input_data[0])
    
    a = input_data[1:n+1]

    freq = Counter(a)

    print(max(freq.values()))

if __name__ == '__main__':
    solve_pockets()
