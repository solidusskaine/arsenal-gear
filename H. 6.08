import sys

def solve_icpc_teams():
    # .read().split() extrae TODOS los números del archivo en una sola lista plana
    tokens = sys.stdin.read().split()
    
    if not tokens:
        return
        
    q = int(tokens[0])
    idx = 1
    out = []
    
    # Iteramos exactamente 'q' veces
    for _ in range(q):
        if idx + 2 < len(tokens):
            c = int(tokens[idx])
            m = int(tokens[idx+1])
            x = int(tokens[idx+2])
            idx += 3
            
            # Calculamos la fórmula matemática en tiempo O(1)
            ans = min(c, m, (c + m + x) // 3)
            out.append(str(ans))
            
    # Imprimimos todos los resultados separados por un salto de línea
    print('\n'.join(out))

if __name__ == '__main__':
    solve_icpc_teams()
