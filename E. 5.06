import sys

def solve_kefa_and_first_steps():
 
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
  
    n = int(input_data[0])
    
   
    a = [int(x) for x in input_data[1:n+1]]
    
   
    if n == 0:
        print(0)
        return
    if n == 1:
        print(1)
        return
        
    max_len = 1
    current_len = 1
    
   
    for i in range(1, n):
        # Si el número actual es mayor o igual al anterior, la racha continúa
        if a[i] >= a[i-1]:
            current_len += 1
        else:
            # Si la racha se rompe, guardamos el máximo y reiniciamos el contador
            max_len = max(max_len, current_len)
            current_len = 1
            
 
    max_len = max(max_len, current_len)
    
    # Imprimimos la respuesta requerida
    print(max_len)

if __name__ == '__main__':
    solve_kefa_and_first_steps()
